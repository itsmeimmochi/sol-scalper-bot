# Copy to observer/.env (gitignored). Paths below are on the Docker *host* (your Mac).

# --- SSH: remote container logs (restricted user; see observer/README.md) ---
OBSERVER_SSH_LOGS_KEY_HOST_PATH=/absolute/path/to/scalper_logs_ed25519
OBSERVER_SSH_LOGS_HOST=coolify.example.com
OBSERVER_SSH_LOGS_USER=scalper-observer
OBSERVER_SSH_LOGS_KEY_FILE=/run/observer/ssh_logs_key
# OBSERVER_SSH_LOGS_PORT=22

# --- Read-only Postgres (observer DB role; not the bot's DATABASE_URL) ---
# If you forward Postgres to your Mac: ssh -N -L 5433:127.0.0.1:5432 ...
# OBSERVER_DATABASE_URL=postgresql://scalper_observer:PASSWORD@host.docker.internal:5433/scalper
OBSERVER_DATABASE_URL=postgresql://scalper_observer:PASSWORD@host.docker.internal:5433/scalper

# OBSERVER_POLL_INTERVAL_SECONDS=30
# OBSERVER_POSITION_POLL_INTERVAL_SECONDS=60
# OBSERVER_CONFIG_POLL_INTERVAL_SECONDS=60

# OBSERVER_SSH_STRICT_HOST_KEY_CHECKING=accept-new

# Set to 0 to only poll DB (no SSH log stream)
# OBSERVER_ENABLE_REMOTE_LOGS=1

# Optional: open SSH tunnel from inside the container (separate tunnel key recommended)
# OBSERVER_SSH_DB_TUNNEL=1
# OBSERVER_SSH_TUNNEL_KEY_HOST_PATH=/absolute/path/to/scalper_tunnel_ed25519
OBSERVER_SSH_TUNNEL_KEY_FILE=/run/observer/ssh_tunnel_key
# OBSERVER_SSH_TUNNEL_HOST=coolify.example.com
# OBSERVER_SSH_TUNNEL_USER=scalper-tunnel
# OBSERVER_SSH_TUNNEL_REMOTE_SPEC=127.0.0.1:5432
# OBSERVER_TUNNEL_LOCAL_PORT=15432
# OBSERVER_SSH_TUNNEL_PORT=22
# When tunnel is on, point OBSERVER_DATABASE_URL at postgresql://...@127.0.0.1:15432/...
