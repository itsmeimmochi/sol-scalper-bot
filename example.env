# Copy to .env and fill in values: cp example.env .env
# .env is gitignored. Compose reads variables from the project directory for ${VAR} substitution.

# ------------------------------------------------------------------------------
# App (required for: npm start, or any run outside compose where compose sets DATABASE_URL)
# ------------------------------------------------------------------------------
# Local Postgres (matches default docker-compose db service when using host port 5432):
DATABASE_URL=postgresql://scalper:scalper@127.0.0.1:5432/scalper

# ------------------------------------------------------------------------------
# Wallet — required when bot config has dryRun: false (live trading)
# ------------------------------------------------------------------------------
# Output of: npm run wallet  (JSON array of secret key bytes, single line)
# WALLET_SECRET_KEY=[1,2,3,...]

# ------------------------------------------------------------------------------
# Telegram (optional)
# ------------------------------------------------------------------------------
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# ------------------------------------------------------------------------------
# Docker Compose only — used in docker-compose.yml for db + ${...} substitution
# (The bot service gets DATABASE_URL from compose; you can still set secrets below.)
# ------------------------------------------------------------------------------
# POSTGRES_USER=scalper
# POSTGRES_PASSWORD=scalper
# POSTGRES_DB=scalper
# Host port when another service already uses 5432 on the machine:
# POSTGRES_HOST_PORT=5432
